# =============================================================================
# PipelineIQ API — Environment Variables
# Copy to .env and fill in values
# =============================================================================

# --- App ---
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# --- Database (Neon.tech) ---
# Pooled connection (for app runtime) — hostname has -pooler
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
# Direct connection (for drizzle-kit migrations) — no -pooler
DATABASE_URL_DIRECT=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# --- Redis (Upstash) ---
# Use the rediss:// TLS URL from Upstash dashboard (Details tab → REDIS_URL)
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# --- JWT (RS256) ---
# Generate with: node scripts/generate-keys.js
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxx\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nxxx\n-----END PUBLIC KEY-----"

# --- Google OAuth ---
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/auth/google/callback

# --- GitHub App (fill in Phase 2) ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- OpenAI (fill in Phase 4) ---
OPENAI_API_KEY=

# --- Pinecone (fill in Phase 4) ---
PINECONE_API_KEY=
PINECONE_INDEX_NAME=pipelineiq-postmortems

# --- Stripe (fill in Phase 7) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_ANNUAL=
STRIPE_PRICE_ID_TEAM_MONTHLY=
STRIPE_PRICE_ID_TEAM_ANNUAL=

# --- Resend (email) ---
RESEND_API_KEY=

# --- ML Lambda (fill in Phase 5) ---
ML_LAMBDA_FUNCTION_URL=

# --- Frontend ---
FRONTEND_URL=http://localhost:3002
