{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "paths": {
      "@pipelineiq/shared": ["../../packages/shared/src/index.ts"],
      "@pipelineiq/shared/*": ["../../packages/shared/src/*.ts"]
    }
  },
  "references": [
    { "path": "../../packages/shared" }
  ],
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
